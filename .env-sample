# 🔹 Selector de proveedor: gemini | groq | openrouter
LLM_PROVIDER=groq

# 🔹 Configuración GROQ (free tier: ~30 req/min, 14k tokens/min)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=4096

# 🔹 Configuración OPENROUTER (muchos modelos gratuitos)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=4096

# ==============================
# GOOGLE GEMINI / IA
# ==============================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash  # Modelo rápido y eficiente
GEMINI_TEMPERATURE=0.2  # Baja temperatura para código preciso (0.0-1.0)
GEMINI_MAX_TOKENS=4096  # Límite de respuesta

TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

DB_PATH="./memory.db"

SSL_CERT_FILE=C:/Users/pedrodulce/develop/antigravity/combined-ca.pem
REQUESTS_CA_BUNDLE=C:/Users/pedrodulce/develop/antigravity/combined-ca.pem
CURL_CA_BUNDLE=C:/Users/pedrodulce/develop/antigravity/combined-ca.pem

# 1. Establecer variables de entorno para la sesión actual
HTTPS_PROXY = "http://proxycocs.redsara.es:8080"
HTTP_PROXY = "http://proxycocs.redsara.es:8080"
NO_PROXY = "localhost,127.0.0.1,.local"
GOOGLE_API_PROXY = "http://proxycocs.redsara.es:8080"
GRPC_PROXY = "http://proxycocs.redsara.es:8080"

# ==============================
# DIRECTORIOS PARA GENERACIÓN DE PROYECTOS
# ==============================
# El bot puede CREAR proyectos en esta carpeta (con subcarpetas)
OUTPUT_DIRECTORY=C:/Users/pedrodulce/develop/generated

# Timeout máximo para generación de proyectos (en segundos)
PROJECT_GENERATION_TIMEOUT=1800  # 30 minutos

# Límite de archivos que puede generar un proyecto
MAX_FILES_PER_PROJECT=100